# Firebase-Konfiguration (Werte aus der Firebase-Konsole kopieren:
# Projekteinstellungen -> Allgemein -> "Meine Apps" -> Web-App -> SDK-Konfiguration)
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=mein-projekt.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://mein-projekt-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=mein-projekt
VITE_FIREBASE_STORAGE_BUCKET=mein-projekt.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
